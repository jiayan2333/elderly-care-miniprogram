page {
  background-color: #ffffff !important;
}

.container { 
  width: 100vw; 
  height: 100vh; 
  position: relative; 
  background: #ffffff; 
}

.menu-wrapper {
  position: fixed;
  top: 25rpx; 
  left: 30rpx;
  z-index: 9999;
}
.menu-main {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid #e0e0e0;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}
.breath-dot {
  width: 16rpx;
  height: 16rpx;
  background: #34c759;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: breathe 2s infinite;
}
.menu-title { color: #333; font-size: 24rpx; font-weight: 500; }

.menu-list {
  margin-top: 15rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}
.menu-item {
  color: #007aff;
  font-size: 28rpx;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.logo-video-ball {
  position: fixed;
  z-index: 10001;
  transition: all 0.5s ease;
  background-color: #ffffff !important; 
}

/* 初始大屏状态：铺满全屏 */
.logo-video-ball.fullscreen {
  width: 100vw;
  height: 100vh;
  left: 0;
  top: 0;
}

/* 缩小后状态：居中方形 */
.logo-video-ball.fixed-top-square {
  width: 150rpx;
  height: 180rpx;
  top: 10rpx; 
  left: 50%;
  margin-left: -75rpx;
  /* 由圆形改为带微圆角的方形 */
  border-radius: 16rpx; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.guide-tips {
  position: fixed;
  /* 调整到屏幕约 2/3 的位置 */
  bottom: 25%; 
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10002;
}

.guide-text-gradient {
  display: inline-block;
  padding: 24rpx 48rpx;
  border-radius: 60rpx;
  background-image: linear-gradient(135deg, #6e8efb 0%, #a777e3 100%) !important;
  color: #ffffff !important;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 30rpx rgba(110, 142, 251, 0.5);
  border: 4rpx solid rgba(255, 255, 255, 0.8) !important;
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

/* 备用动画逻辑 */
@keyframes breathe {
  0% { transform: scale(0.9); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(0.9); opacity: 0.5; }
}