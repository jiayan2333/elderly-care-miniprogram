}

.bank-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  margin-right: 18rpx;
  font-size: 36rpx;
  flex-shrink: 0;
  color: #fff;
  font-weight: bold;
  font-size: 20rpx;
