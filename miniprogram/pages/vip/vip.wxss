}

.confirm-bank-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(79, 172, 254, 0.32);
  letter-spacing: 2rpx;
  transition: all 0.3s;
  flex-shrink: 0;
}

.confirm-bank-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shimmer 2s infinite;
}

.confirm-bank-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(79, 172, 254, 0.25);
}

.confirm-bank-btn[disabled] {
  background: linear-gradient(135deg, #D9D9D9 0%, #B8B8B8 100%);
  box-shadow: none;
  opacity: 0.65;
}

.confirm-bank-btn[disabled]::before {
  animation: none;
}
