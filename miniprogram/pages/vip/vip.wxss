.comm {
  background: linear-gradient(135deg, #003287 0%, #002870 100%);
}

.cmb {
  background: linear-gradient(135deg, #C6000B 0%, #A30008 100%);
}

.spdb {
  background: linear-gradient(135deg, #1D5A93 0%, #174B7A 100%);
}

.bank-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2A3A;
  flex: 1;
}

.bank-check {
  width: 36rpx;
