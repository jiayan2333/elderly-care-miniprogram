
.container { min-height: 100vh; background-color: #FFFBEB; padding-bottom: 180rpx; }
.image-header { position: relative; width: 100%; height: 500rpx; background-color: #FDE68A; }
.cover-image { width: 100%; height: 100%; }
.image-mask { position: absolute; bottom: 0; left: 0; right: 0; height: 100rpx; background: linear-gradient(to top, #FFFBEB, transparent); }
.header-card { position: relative; margin: -50rpx 30rpx 30rpx; padding: 40rpx; background: #fff; border-radius: 30rpx; box-shadow: 0 10rpx 30rpx rgba(120, 53, 15, 0.08); }
.name { font-size: 52rpx; font-weight: bold; color: #451A03; display: block; }
.school { font-size: 28rpx; color: #713F12; margin-top: 10rpx; display: block; }
.stats { display: flex; margin-top: 24rpx; }
.stat-item { font-size: 24rpx; color: #92400E; background: #FEF3C7; padding: 8rpx 20rpx; border-radius: 40rpx; margin-right: 20rpx; }
.card { background: #fff; margin: 0 30rpx 24rpx; padding: 30rpx; border-radius: 24rpx; }
.card-title { font-size: 34rpx; font-weight: bold; color: #78350F; margin-bottom: 20rpx; border-left: 10rpx solid #D97706; padding-left: 20rpx; }
.info-row { display: flex; justify-content: space-between; margin-bottom: 10rpx; font-size: 28rpx; color: #92400E; }
.tags { display: flex; flex-wrap: wrap; margin-top: 10rpx; }
.tag { background: #FFF9E1; color: #92400E; font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 8rpx; margin: 0 16rpx 16rpx 0; border: 1rpx solid #FDE68A; }
.introduction { font-size: 30rpx; color: #713F12; line-height: 1.8; }
.footer { position: fixed; bottom: 0; width: 100%; background: #fff; display: flex; padding: 20rpx 30rpx 60rpx; box-sizing: border-box; align-items: center; box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.05); z-index: 99; }
.price-info { flex: 1; }
.price-label { font-size: 24rpx; color: #92400E; display: block; }
.price-value { font-size: 38rpx; color: #D97706; font-weight: bold; }
.btn-book { flex: 1.8; background: linear-gradient(135deg, #B45309 0%, #92400E 100%); color: #fff; border-radius: 50rpx; height: 100rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; border: none; }
.booked { background: #D1D5DB !important; color: #6B7280 !important; }

/* ================= 预约表单弹窗核心样式 ================= */
.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.6); z-index: 100; }
.time-picker { position: fixed; bottom: -100%; left: 0; right: 0; background: #fff; border-radius: 40rpx 40rpx 0 0; padding: 40rpx 30rpx 30rpx; z-index: 101; transition: all 0.3s ease-out; max-height: 90vh; display: flex; flex-direction: column; }
.time-picker.show { bottom: 0; }

.picker-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; padding: 0 10rpx; }
.picker-title { font-size: 36rpx; font-weight: bold; color: #333; }
.close-btn { font-size: 40rpx; color: #999; padding: 10rpx; }

.form-scroll { flex: 1; overflow-y: scroll; padding-bottom: 30rpx; }

/* 输入控件样式 */
.form-section { background: #F9FAFB; border-radius: 20rpx; padding: 20rpx; margin-bottom: 30rpx; }
.input-group { margin-bottom: 24rpx; }
.input-label { font-size: 28rpx; color: #4B5563; margin-bottom: 12rpx; display: block; }
.required { color: #EF4444; margin-left: 4rpx; }
.input-field { background: #fff; border: 2rpx solid #E5E7EB; border-radius: 12rpx; height: 80rpx; padding: 0 24rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.textarea-field { background: #fff; border: 2rpx solid #E5E7EB; border-radius: 12rpx; height: 160rpx; padding: 20rpx 24rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }

/* 地图选择器 */
.address-box { display: flex; align-items: center; gap: 16rpx; }
.address-input { flex: 1; }
.location-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; background: #FEF3C7; color: #D97706; padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 22rpx; min-width: 80rpx; border: 1rpx solid #FDE68A; }
.loc-icon { font-size: 32rpx; }

.form-label-title { font-size: 30rpx; font-weight: bold; color: #374151; margin: 30rpx 10rpx 20rpx; }

/* 日期与时间列表修复 */
.date-scroll-view { display: flex; white-space: nowrap; margin-bottom: 30rpx; width: 100%; }
.date-item { display: inline-flex; flex-direction: column; align-items: center; padding: 20rpx 0; min-width: 130rpx; flex-shrink: 0; position: relative; }
.date-item.disabled { opacity: 0.3; filter: grayscale(100%); }
.date-item.active { color: #D97706; font-weight: bold; }
.week-text { font-size: 24rpx; color: #6B7280; }
.date-text { font-size: 28rpx; margin-top: 6rpx; }
.active-line { position: absolute; bottom: 0; width: 50rpx; height: 6rpx; background: #D97706; border-radius: 3rpx; }

.time-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 0 10rpx; }
.time-card { border: 2rpx solid #E5E7EB; border-radius: 12rpx; padding: 24rpx 0; text-align: center; background: #fff; }
.time-card.active { border-color: #F87171; background: #FFF1F2; color: #EF4444; }
.time-range { font-size: 26rpx; }

.confirm-submit-btn { background: linear-gradient(135deg, #EF4444, #DC2626); color: #fff; border-radius: 50rpx; height: 100rpx; line-height: 100rpx; font-size: 34rpx; font-weight: bold; margin-top: 20rpx; width: 100% !important; border: none; box-shadow: 0 10rpx 20rpx rgba(239, 68, 68, 0.2); }

.loading { text-align: center; padding-top: 200rpx; color: #92400E; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #FEF3C7; border-top: 6rpx solid #D97706; border-radius: 50%; margin: 0 auto 20rpx; animation: spin 1s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }