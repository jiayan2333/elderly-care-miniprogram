
.container {
    min-height: 100vh;
    background: #f5f5f5;
    padding-bottom: 140rpx;
}

.banner-swiper {
    width: 100%;
    height: 536rpx;
    margin-bottom: 24rpx;
}

.banner-image {
    width: 100%;
    height: 100%;
    cursor: pointer;
}

.banner-image:active {
    opacity: 0.9;
}

.header {
    background: linear-gradient(135deg, #8EC7FC 0%, #DEC4FF 100%);
    padding: 50rpx 30rpx;
    margin: 0 30rpx 24rpx;
    border-radius: 24rpx;
    position: relative;
    z-index: 10;
    box-shadow: 0 12rpx 32rpx rgba(142, 199, 252, 0.35);
    overflow: hidden;
}

.header-deco {
    position: absolute;
    top: -50rpx;
    right: -50rpx;
    width: 200rpx;
    height: 200rpx;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
}

.header-deco::before {
    content: '';
    position: absolute;
    bottom: 20rpx;
    left: -30rpx;
    width: 100rpx;
    height: 100rpx;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
}

.header-content {
    position: relative;
    z-index: 1;
    text-align: center;
}

.name {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #0D47A1;
    margin-bottom: 12rpx;
}

.title {
    display: block;
    font-size: 28rpx;
    color: #0D47A1;
    margin-bottom: 24rpx;
    font-weight: 300;
}

.stats {
    display: flex;
    justify-content: center;
    gap: 20rpx;
}

.stat-item {
    font-size: 24rpx;
    color: #0D47A1;
    padding: 10rpx 24rpx;
    background: rgba(13, 71, 161, 0.1);
    border-radius: 24rpx;
}

.card {
    background: #ffffff;
    margin: 24rpx 30rpx;
    padding: 30rpx;
    border-radius: 16rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333333;
    margin-bottom: 24rpx;
    padding-bottom: 16rpx;
    border-bottom: 2rpx solid #f0f0f0;
}

.info-row {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
}

.label {
    font-size: 28rpx;
    color: #666666;
    width: 160rpx;
    flex-shrink: 0;
}

.value {
    font-size: 28rpx;
    color: #333333;
    flex: 1;
}

.tags {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
    margin-top: 20rpx;
}

.tag {
    font-size: 24rpx;
    color: #8EC7FC;
    padding: 8rpx 24rpx;
    background: rgba(142, 199, 252, 0.15);
    border-radius: 24rpx;
}

.introduction {
    font-size: 28rpx;
    color: #666666;
    line-height: 1.8;
}

.specialties {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
}

.specialty-item {
    background: linear-gradient(135deg, #8EC7FC 0%, #DEC4FF 100%);
    padding: 24rpx;
    border-radius: 12rpx;
    text-align: center;
}

.specialty-item text {
    font-size: 28rpx;
    color: #0D47A1;
}

.footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #ffffff;
    padding: 20rpx 30rpx;
    display: flex;
    align-items: center;
    gap: 24rpx;
    box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.price-info {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
}

.price-label {
    font-size: 22rpx;
    color: #999999;
    margin-bottom: 4rpx;
}

.price-value {
    font-size: 36rpx;
    font-weight: bold;
    color: #8EC7FC;
}

.btn-book {
    flex: 1;
    height: 88rpx;
    background: linear-gradient(135deg, #8EC7FC 0%, #DEC4FF 100%);
    color: #0D47A1;
    font-size: 30rpx;
    border-radius: 44rpx;
    padding: 0;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    box-shadow: 0 6rpx 20rpx rgba(142, 199, 252, 0.4);
}

.btn-book:active {
    transform: scale(0.98);
    box-shadow: 0 4rpx 12rpx rgba(142, 199, 252, 0.3);
}

.btn-icon {
    font-size: 32rpx;
}

.btn-text {
    font-weight: 500;
}

.loading {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background: #f5f5f5;
}

.loading text {
    font-size: 28rpx;
    color: #999999;
}
