/* 页面背景 */
.container {
  min-height: 100vh;
  background-color: #FFFBEB; /* 奶油淡黄 */
  padding-bottom: 30rpx;
}

/* 头部装饰 */
.header {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #78350F; /* 深咖啡棕 */
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: #92400E; /* 中棕色 */
}

/* 预约贴纸样式 */
.appointment-sticker {
  margin: 30rpx;
  background: #ffffff;
  border: 4rpx solid #D97706; /* 匹配主色调的边框 */
  border-radius: 24rpx;
  position: relative;
  padding: 24rpx 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(217, 119, 6, 0.15);
  animation: slideIn 0.4s ease-out; /* 丝滑入场动画 */
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(-30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.sticker-tag {
  position: absolute;
  top: -18rpx;
  right: 24rpx;
  background: #D97706;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  font-weight: bold;
}

.sticker-content {
  display: flex;
  align-items: center;
}

.sticker-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #FDE68A;
  flex-shrink: 0;
}

.sticker-info {
  flex: 1;
  margin-left: 24rpx;
}

.sticker-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #451A03;
}

.sticker-time {
  font-size: 26rpx;
  color: #D97706;
  margin-top: 6rpx;
  font-weight: 500;
}

.sticker-cancel {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx;
  text-decoration: underline;
}

/* 列表卡片 */
.volunteer-list {
  padding: 30rpx;
}

/* 卡片样式 */
.volunteer-card {
  display: flex;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(120, 53, 15, 0.05);
  border-left: 10rpx solid #D97706; /* 左侧暖橙色点缀 */
}

/* 头像 */
.volunteer-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  background-color: #FEF3C7;
  flex-shrink: 0;
  border: 4rpx solid #FDE68A;
}

/* 文字信息区 */
.volunteer-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.volunteer-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #451A03;
  margin-bottom: 8rpx;
}

.volunteer-intro {
  font-size: 30rpx;
  color: #713F12;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2; /* 限制两行显示 */
  overflow: hidden;
}

/* 查看详情按钮 */
.volunteer-btn {
  display: inline-block;
  padding: 12rpx 36rpx;
  background: linear-gradient(135deg, #B45309 0%, #92400E 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 50rpx;
  text-align: center;
  align-self: flex-start;
  margin-top: 10rpx;
}