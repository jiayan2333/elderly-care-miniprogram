
<view class="container">

<!--  顶部标题 -->
<view class="header">
  <view class="title-section">
    <text class="main-title">健康记录</text>
    <text class="sub-title">记录每日健康状况</text>
  </view>
</view>

<!--  新增记录输入区  -->
<view class="record-area">
  <view class="input-header">
    <text class="input-title">新增健康记录</text>
    <text class="char-count">{{recordContent.length}} / 500</text>
  </view>

  <textarea
    class="record-input"
    placeholder="请记录今天的健康状况、症状、用药情况、感受等..."
    placeholder-class="placeholder"
    value="{{recordContent}}"
    bindinput="onInputChange"
    maxlength="500"
    auto-height
    show-confirm-bar="false"
  />

  <view class="input-footer">
    <text class="tip-text">💡 提示：每天记录有助于发现健康变化</text>
  </view>

  <button
    class="save-btn"
    bindtap="saveRecord"
  >
    💾 保存记录
  </button>
</view>

<!-- 历史记录  -->
<view class="history-section">

  <!-- 历史记录头 -->
  <view class="history-header">
    <text class="history-title">历史记录</text>
    <button
      wx:if="{{records.length}}"
      class="clear-btn"
      bindtap="clearAllRecords"
    >
      清空全部
    </button>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{records.length === 0}}" class="empty-wrap">
    <text class="empty-text">暂无健康记录</text>
  </view>

  <!-- 记录列表 -->
  <block wx:for="{{records}}" wx:key="id">
    <view class="record-card">

      <!-- 单条记录 -->
      <view
        class="record-item"
        bindtap="toggleRecord"
        data-index="{{index}}"
      >
        <!-- 记录头部：时间标签 -->
        <view class="record-header">
          <text class="icon">🕐</text>
          <text class="time">{{item.timeText}}</text>
          <text class="arrow">
            {{item.expanded ? '取消展开' : '点击展开'}}
          </text>
        </view>

        <!-- 展开内容 -->
        <view wx:if="{{item.expanded}}" class="record-content">
          {{item.content}}
        </view>
      </view>

    </view>
  </block>

</view>

<!--  底部提示  -->
<view class="bottom-tips">
  <text class="tips-text">记录内容仅保存在本地设备</text>
</view>

</view>
