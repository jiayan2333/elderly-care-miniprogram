

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/*  顶部标题 */
.header {
  margin-bottom: 40rpx;
}

.title-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.main-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.sub-title {
  font-size: 28rpx;
  color: #666;
}

/*  新增记录输入区  */
.record-area {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.input-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.char-count {
  font-size: 26rpx;
  color: #999;
}

.record-input {
  width: 100%;
  min-height: 360rpx;
  padding: 30rpx;
  font-size: 32rpx;
  line-height: 1.6;
  background: #fafafa;
  color: #333;
}

.placeholder {
  color: #bbb;
  font-size: 30rpx;
}

.input-footer {
  padding: 20rpx 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
}

/* 保存按钮 */
.save-btn {
  margin: 30rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 18rpx;
  padding: 28rpx 0;
}

.save-btn:active {
  opacity: 0.9;
  transform: translateY(4rpx);
}

/* 历史记录 */
.history-section {
  margin-bottom: 40rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.history-title {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
}

.clear-btn {
  font-size: 26rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-wrap {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 单条记录卡片 */
.record-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.record-header {
  margin-bottom: 12rpx;
}

.record-time {
  font-size: 26rpx;
  color: #999;
}

.record-content {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

/* 底部提示  */
.bottom-tips {
  text-align: center;
  padding: 30rpx 0;
}

.tips-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}
