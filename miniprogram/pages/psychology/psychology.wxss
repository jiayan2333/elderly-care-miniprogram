
/* 页面整体容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #E3F2FD;
  box-sizing: border-box;
}

/* 轮播图容器 */
.swiper-container {
  margin: 0 0 40rpx 0;
}

.swiper {
  width: 100%;
  height: 400rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(33, 150, 243, 0.25);
  border: 4rpx solid #fff;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 按钮容器 */
.btn-container {
  margin-bottom: 40rpx;
}

/* 跳转按钮 */
.jump-btn {
  background: linear-gradient(135deg, #90CAF9 0%, #64B5F6 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 30rpx 60rpx;
  box-shadow: 0 8rpx 16rpx rgba(100, 181, 246, 0.3);
  border: none;
  width: 100%;
}

.jump-btn:active {
  background: linear-gradient(135deg, #81D4FA 0%, #42A5F5 100%);
  transform: scale(0.98);
}

/* 视频列表整体 */
.video-list {
  margin-top: 20rpx;
}

/* 单个视频卡片 */
.video-item {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.12);
  border: 1rpx solid #BBDEFB;
}

/* 视频标题 */
.video-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976D2;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 标题前的小装饰 */
.video-title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #90CAF9, #64B5F6);
  margin-right: 16rpx;
  border-radius: 4rpx;
}

/* 视频本体样式 */
video {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #000;
  display: block;
}
