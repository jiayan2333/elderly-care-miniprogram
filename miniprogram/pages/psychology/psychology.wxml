<view class="container">
  <!-- 轮播图 -->
  <view class="swiper-container">
    <swiper
      class="swiper"
      indicator-dots="{{true}}"
      autoplay="{{true}}"
      interval="{{3000}}"
      duration="{{500}}"
      circular="{{true}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="#fff"
    >
      <swiper-item wx:for="{{bannerList}}" wx:key="index">
        <image
          class="swiper-image"
          src="{{item}}"
          mode="aspectFill"
        />
      </swiper-item>
    </swiper>
  </view>

  <!-- 进入心理咨询按钮 -->
  <view class="btn-container">
    <button class="jump-btn" bindtap="navigateToMiniProgram">
      进入心理咨询
    </button>
  </view>

  <!-- 视频列表 -->
  <view class="video-list">
    <view
      class="video-item"
      wx:for="{{videoList}}"
      wx:key="index"
    >
      <text class="video-title">{{item.title}}</text>

      <video
        src="{{item.url}}"
        poster="cloud://cloud-littlename-5f59ieubb03a1e3.636c-cloud-littlename-5f59ieubb03a1e3-1404543063/userimg/心理关怀/老年心理健康.jpg"
        controls
        show-mute-btn="{{true}}"
        enable-play-gesture="{{true}}"
        vnet-detach="{{false}}"
        play-btn-position="center"
        object-fit="cover"
      ></video>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>