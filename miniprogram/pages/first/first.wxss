/* 页面全局 */
   .container {
    background-color: #E6F3F5; 
    padding: 30rpx;
    padding-bottom: 100rpx;
  }
  
  /* 顶部 Banner 与 Header */
  .top-banner {
    width: 100%;
    height: 400rpx; 
    overflow: hidden;
    margin-bottom: 40rpx;
  }
  .top-banner-img {
    width: 100%;
    height: 100%;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 40rpx;
  }
  .header-left { display: flex; flex-direction: column; }
  .title { font-size: 48rpx; font-weight: bold; color: #1A5F7A; line-height: 54rpx; }
  .subtitle { font-size: 32rpx; color: #579BB1; margin-top: 10rpx; line-height: 38rpx; }
  .header-right { text-align: right; }
  .temp { font-size: 48rpx; font-weight: bold; color: #2A8CFF; line-height: 54rpx; }
  .weather-desc { font-size: 24rpx; color: #888; margin-top: 4rpx; }
  
  /* 功能卡片*/
  .card {
    background: #fff;
    border-radius: 40rpx;
    padding: 40rpx;
    margin-bottom: 30rpx;
    border: 1rpx solid #D1E9ED;
  }
  .card-header { display: flex; align-items: center; margin-bottom: 30rpx; }
  .card-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
  .flex-row { display: flex; align-items: center; }
  .card-title { font-size: 36rpx; font-weight: bold; margin-left: 15rpx; color: #1A5F7A; }
  .more { font-size: 26rpx; color: #2A8CFF; }
  
  /* 健康管理与提醒 */
  .medicine-card {
    position: relative;
    margin: 24rpx;
    padding: 32rpx 28rpx 36rpx;
    border-radius: 20rpx;
    background: linear-gradient(135deg, #E0F7FA, #F1F9FA);
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
    font-size: 30rpx;
    color: #333;
  }
  .medicine-close { position: absolute; top: 16rpx; right: 20rpx; width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center; font-size: 36rpx; color: #999; }
  .medicine-title { font-size: 34rpx; font-weight: 600; color: #00838F; margin-bottom: 18rpx; }
  .medicine-content { font-size: 30rpx; line-height: 1.6; margin-bottom: 14rpx; }
  .medicine-time { color: #2A8CFF; font-weight: 600; padding: 0 6rpx; }
  .medicine-sub { font-size: 26rpx; color: #888; margin-bottom: 26rpx; }
  .medicine-btn { width: 100%; height: 88rpx; line-height: 88rpx; text-align: center; font-size: 32rpx; font-weight: 600; color: #fff; border-radius: 44rpx; background: linear-gradient(135deg, #4FACFE, #00F2FE); }
  .medicine-btn:active { opacity: 0.85; }
  
  .status-item { padding: 30rpx; border-radius: 30rpx; display: flex; flex-direction: column; align-items: center; }
  .icon-circle { background: #fff; width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 15rpx; }
  .bg-red { background-color: #E3F2FD; }
  .bg-blue { background-color: #E0F7FA; }
  .bg-yellow { background-color: #E8F5E9; }
  .bg-pink { background-color: #F3E5F5; }
  .bg-gold { background-color: #E0F2F1; }
  
  /*  志愿者陪伴与心理关怀 */
  .volunteer-scroll { white-space: nowrap; }
  .volunteer-item { display: inline-flex; flex-direction: column; align-items: center; width: 220rpx; margin-right: 20rpx; }
  .avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 6rpx solid #F1F9FA; }
  .v-name { font-size: 32rpx; font-weight: bold; margin-top: 15rpx; color: #1A5F7A; }
  .v-skill { font-size: 24rpx; color: #666; }
  
  .psychology-scroll { width: 600rpx; height: 250rpx; border-radius: 12rpx; object-fit: cover; }
  .psychology-img { width: 600rpx; height: 200rpx; border-radius: 12rpx; object-fit: cover; }
  
  /*  家政服务与每日推荐 */
  .home-service-scroll { white-space: nowrap; }
  .home-service-img { width: 103%; height: 235rpx; border-radius: 12rpx; }
  
  .video-box { border-radius: 24rpx; overflow: hidden; background: #F0F9FA; }
  .recommend-video { width: 100%; height: 320rpx; background: #000; }
  .video-placeholder { display: none; }
  .video-info { padding: 20rpx; font-size: 28rpx; color: #666; }
  
  /* 生活与学习 (网格布局)*/
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
  .service-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24rpx 10rpx; background: #F0F9FA; border-radius: 24rpx; font-size: 26rpx; height: 130rpx; overflow: hidden; color: #1A5F7A; }
  .service-img { width: 100%; height: 100%; border-radius: 24rpx; display: block; }
  .service-icon { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-bottom: 12rpx; }
  
  /*  社区活动 */
  .activity-entry { margin-top: 40rpx; padding-bottom: 20rpx; }
  .entry-header { display: flex; justify-content: space-between; align-items: center; padding: 0 30rpx; margin-bottom: 20rpx; }
  .entry-title { font-size: 32rpx; font-weight: 600; color: #1A5F7A; }
  .entry-more { font-size: 24rpx; color: #2A8CFF; }
  .entry-scroll { white-space: nowrap; padding-left: 30rpx; }
  .entry-card { display: inline-flex; flex-direction: column; width: 280rpx; margin-right: 20rpx; background: #ffffff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 6rpx 16rpx rgba(160, 200, 210, 0.1); border: 1rpx solid #D1E9ED; }
  .card-cover { width: 100%; height: 160rpx; background: #F0F9FA; }
  .entry-card .card-title { font-size: 28rpx; font-weight: 600; color: #333; padding: 16rpx 16rpx 8rpx; line-height: 1.4; }
  .entry-card .official-tag { margin: 0 16rpx 8rpx; font-size: 22rpx; color: #fff; background: #4FACFE; padding: 2rpx 10rpx; border-radius: 10rpx; width: fit-content; }
  .entry-card .card-meta { font-size: 24rpx; color: #6BB1BD; padding: 0 16rpx 16rpx; }
  
  /* 加载与错误态*/
  .loading-wrap, .error-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
  .loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #D1E9ED; border-top-color: #2A8CFF; border-radius: 50%; animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-wrap text, .error-text { font-size: 28rpx; color: #6BB1BD; margin-top: 24rpx; }
  .error-icon { font-size: 80rpx; margin-bottom: 20rpx; }
  .retry-btn { margin-top: 30rpx; background: #2A8CFF; color: #fff; font-size: 28rpx; padding: 20rpx 50rpx; border-radius: 30rpx; }
  
  /* 通用图标*/
  .icon-red, .icon-warm, .icon-green, .icon-purple, .icon-home { font-size: 36rpx; margin-right: 8rpx; }