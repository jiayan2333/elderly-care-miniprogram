    <image src="cloud://cloud-littlename-5f59ieubb03a1e3.636c-cloud-littlename-5f59ieubb03a1e3-1404543063/userimg/志愿者/志愿者.h.jpg" mode="aspectFill" class="avatar" />

    <text class="v-name">季诗洋</text>

    <text class="v-skill">荧欢公司员工</text>

    <text class="v-skill">陪诊 · 就医陪同</text>

  </view>

