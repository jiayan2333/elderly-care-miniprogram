    <image src="cloud://cloud-littlename-5f59ieubb03a1e3.636c-cloud-littlename-5f59ieubb03a1e3-1404543063/userimg/志愿者/志愿者.i.jpg" mode="aspectFill" class="avatar" />

    <text class="v-name">钟欣阳</text>

    <text class="v-skill">荧欢公司员工</text>

    <text class="v-skill">陪练 · 保健养生</text>

  </view>

</scroll-view>

</view>

<view class="card">
  <view class="card-header-flex">
    <view class="flex-row">
      <text class="icon-warm">❤️</text>
      <text class="card-title">心理关怀</text>
    </view>
  </view>
  <view class="psychology-banner" bindtap="goPsychology">
    <image src="{{psychologyBanner}}" mode="aspectFill" class="psychology-img" />
  </view>
</view>

<view class="card">
  <view class="card-header-flex">
    <view class="flex-row">
      <text class="icon-home">🏠</text>
      <text class="card-title">家政服务</text>
    </view>
  </view>
  <view class="home-service-scroll">
    <view class="home-service-item" bindtap="goHomeService">
      <image src="cloud://cloud-littlename-5f59ieubb03a1e3.636c-cloud-littlename-5f59ieubb03a1e3-1404543063/userimg/3.jpg" class="home-service-img" />
    </view>
  </view>
</view>

<view class="card" bindtap="goRecommend">
  <view class="card-header">
    <text class="icon-green">🥗</text>
    <text class="card-title">今日养生推荐</text>
  </view>
  <view class="video-box">
    <video src="{{recommend.videoUrl}}" poster="{{recommend.poster}}" autoplay="{{recommend.videoConfig.autoplay}}" controls="{{recommend.videoConfig.controls}}" loop="{{recommend.videoConfig.loop}}" muted="{{recommend.videoConfig.muted}}" show-center-play-btn="{{recommend.videoConfig.showCenterPlayBtn}}" object-fit="{{recommend.videoConfig.objectFit}}" bindplay="onVideoPlay" bindpause="onVideoPause" binderror="onVideoError" bindended="onVideoEnded" class="recommend-video" enable-play-gesture="{{true}}">
      <view class="video-placeholder">视频加载中...</view>
    </video>
    <view class="video-info"><text>{{recommend.title}}</text></view>
  </view>
</view>

<view class="card">
  <view class="card-header">
    <text class="icon-purple">🧩</text>
    <text class="card-title">生活与学习</text>
  </view>
  <view class="grid-2 services-grid">
    <view class="service-btn" bindtap="goEntertainment"><image src="{{entertainmentImg}}" mode="aspectFill" class="service-img" /></view>
    <view class="service-btn" bindtap="goFood"><image src="{{foodImg}}" mode="aspectFill" class="service-img" /></view>
    <view class="service-btn" bindtap="goStudy"><image src="{{studyImg}}" mode="aspectFill" class="service-img" /></view>
    <view class="service-btn" bindtap="goVip"><image src="{{vipImg}}" mode="aspectFill" class="service-img" /></view>
  </view>
</view>

<view class="activity-entry">
  <view class="entry-header">
    <text class="entry-title">社区活动</text>
    <text class="entry-more" bindtap="goActivityList">查看更多 ></text>
  </view>
  <scroll-view scroll-x class="entry-scroll" show-scrollbar="false">
    <block wx:for="{{activities}}" wx:key="_id">
      <view class="entry-card" bindtap="goActivityDetail" data-id="{{item._id}}">
        <image class="card-cover" src="{{item.cover}}" mode="aspectFill" />
        <text class="card-title">{{item.title}}</text>
        <text wx:if="{{item.isOfficial}}" class="official-tag">官方</text>
        <text class="card-meta">人数：{{item.joinCount}} / {{item.maxPeople}}</text>
      </view>
    </block>
    <view wx:if="{{activities.length === 0}}" class="error-wrap"><text class="error-text">暂无可参加的活动</text></view>
  </scroll-view>
</view>

</view>