<view class="container">

<view class="top-banner">
  <image src="{{topBanner}}" mode="aspectFill" class="top-banner-img" />
</view>
<view class="header">
  <view class="header-left">
    <text class="title">{{userName}}</text>
    <text class="subtitle">今天也是美好的一天</text>
  </view>
  <view class="header-right">
    <text class="temp"> </text>
    <text class="weather-desc"> </text>
  </view>
</view>

<view wx:if="{{needRemind}}" class="medicine-card">
  <view class="medicine-close" bindtap="closeMedicineCard">×</view>
  <view class="medicine-title">💊 吃药提醒</view>
  <view class="medicine-content">
    现在是 <text class="medicine-time">{{nextReminderTime}}</text> ，请按时服药
  </view>
  <view class="medicine-sub">今日剩余 {{remainingCount}} 次</view>
  <view class="medicine-btn" bindtap="takeMedicine">已服药</view>
</view>

<view class="card" bindtap="goHealth">
  <view class="card-header">
    <text class="icon-red">❤️</text>
    <text class="card-title">健康管理</text>
  </view>
  <view class="grid-2">
    <view class="status-item bg-red" bindtap="goFirstTxtpro">
      <view class="icon-circle">💊</view>
      <text class="status-label">每日提醒</text>
      <text class="status-val">查看详情</text>
    </view>
    <view class="status-item bg-blue" bindtap="goFirstClock">
      <view class="icon-circle">🩺</view>
      <text class="status-label">健康记录</text>
      <text class="status-val">查看详情</text>
    </view>
  </view>
</view>

<!-- 志愿者陪伴 -->

<view class="card">

<view class="card-header-flex">

  <view class="flex-row">

    <text class="icon-warm">👥</text>

    <text class="card-title">志愿者陪伴</text>

  </view>

  <text class="more" bindtap="goVolunteer">查看更多 ></text>

