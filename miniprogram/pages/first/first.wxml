    <text class="v-name">方雪</text>

    <text class="v-skill">大学生志愿者</text>

    <text class="v-skill">陪伴 · 散心解闷</text>

  </view>

  <view class="volunteer-item" bindtap="goVolunteer">

    <image src="cloud://cloud-littlename-5f59ieubb03a1e3.636c-cloud-littlename-5f59ieubb03a1e3-1404543063/userimg/志愿者/志愿者.f.jpg" mode="aspectFill" class="avatar" />

    <text class="v-name">董明宇</text>

    <text class="v-skill">大学生志愿者</text>

    <text class="v-skill">陪玩 · 棋牌娱乐</text>

