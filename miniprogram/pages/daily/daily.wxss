
/* 页面整体 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #FFFDE7;
  box-sizing: border-box;
}

/* 轮播图 */
.swiper-container {
  margin: 0 0 40rpx 0;
}

.swiper {
  width: 100%;
  height: 400rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(255, 193, 7, 0.25);
  border: 4rpx solid #fff;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 滑动提示 */
.scroll-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
  padding: 12rpx 0;
}

.hint-text {
  font-size: 26rpx;
  color: #FBC02D;
  letter-spacing: 2rpx;
}

/* 视频列表整体 */
.video-list {
  margin-top: 20rpx;
}

/* 单个视频卡片 */
.video-item {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 193, 7, 0.12);
  border: 1rpx solid #FFF9C4;
}

/* 视频标题 */
.video-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #F57F17;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 标题前的小装饰 */
.video-title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #FFD54F, #FFC107);
  margin-right: 16rpx;
  border-radius: 4rpx;
}

/* 视频本体样式 */
video {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #000;
  display: block;
}
